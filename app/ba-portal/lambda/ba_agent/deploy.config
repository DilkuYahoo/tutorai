[DEFAULT]
# Lambda function configuration for BA Agent
function_name = ba-portal-ba-agent-lambda-function
region = ap-southeast-2
runtime = python3.13
handler = main.lambda_handler
memory = 256
timeout = 30

# IAM role (leave empty for auto-generated name)
role_name = ba-portal-ba-agent-lambda-role

# S3 details
s3_bucket = ba-portal-lambda-bucket

# File paths
script_path = main.py
requirements_file = requirements.txt
