# Copy this file to .env.local and fill in the value.
# Obtain the URL from the SAM deploy output: "ApiEndpoint"
#
#   cd app/ratescan/iac && sam deploy
#   # Look for: ApiEndpoint = https://<id>.execute-api.ap-southeast-2.amazonaws.com/prod
#
VITE_API_URL=https://<api-id>.execute-api.ap-southeast-2.amazonaws.com/prod
